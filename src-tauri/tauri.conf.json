{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ChmlFrp节点推荐器",
  "version": "1.2.2",
  "identifier": "net.chmlfrp.noderecommender",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "ChmlFrp交流社区-节点推荐器",
        "width": 1030,
        "height": 660,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 12,
          "y": 20
        },
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": ["nsis", "dmg", "appimage", "deb"],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/zhengddzz/ChmlFrp-NodeSpeedTest/releases/latest/download/{{target}}-{{arch}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxODc4NDg3OUE4QzY0NTYKUldSV1pJeWFoNFNIZ1NibWpRalJnSzNuM0dIVTN3ZDZGWTkzZTI0eHBzL2UxdEpvZ0h4eDdxYm4K"
    }
  }
}
